{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:debug-dev": "nest start --debug --watch",
    "start:local-debug": "NODE_ENV=local nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test:unit": "vitest run test/unit",
    "test:int": "vitest run --config vitest.config.integration.ts test/integration",
    "test:int-setup": "NODE_ENV=test ts-node test/integration/integrationTestSetup.ts",
    "test:e2e-setup": "NODE_ENV=test ts-node test/integration/integrationTestSetup.ts",
    "test:e2e": "playwright test test/e2e",
    "test:e2e-ui": "playwright test --ui test/e2e",
    "test:all": "pnpm test:unit && pnpm test:int && pnpm test:e2e",
    "db:push": "prisma db push",
    "db:show": "prisma studio",
    "db:gen": "prisma generate",
    "seed": "NODE_ENV=local ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/credential-providers": "^3.1069.0",
