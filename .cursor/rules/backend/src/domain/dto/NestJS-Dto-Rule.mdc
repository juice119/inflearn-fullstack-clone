### Response

```typescript
export class CreateCourseResponseDto {
  private readonly _id: string;
  private readonly _title: string;

  constructor({ id, title }: { id: string; title: string }) {
    this._id = id;
    this._title = title;
  }

  @Expose()
  @ApiProperty({ type: String, description: 'Ļ░ĢņØś ID', example: 'uuid', required: true })
  get id(): string {
    return this._id;
  }

  @Expose()
  @ApiProperty({ type: String, description: 'Ļ░ĢņØś ņĀ£ļ¬®', example: 'NestJS ļ¦łņŖżĒä░', required: true })
  get title(): string {
    return this._title;
  }

  static from(record: CreateCourseRecordDto): CreateCourseResponseDto {
    return new CreateCourseResponseDto({ id: record.id, title: record.title });
  }
}
```

## 7. Data Flow

### Default (with `Command`)

```
CreateCourseRequestDto
  ŌåÆ CreateCourseCommandDto
    ŌåÆ CreateCourseParamsDto
      ŌåÆ CreateCourseRecordDto
        ŌåÆ CreateCourseResultDto
          ŌåÆ CreateCourseResponseDto
```

### Exception (skip `Command`)

```
CreateCourseRequestDto + separate args (Ōēż3)
  ŌåÆ CreateCourseParamsDto
    ŌåÆ CreateCourseRecordDto
      ŌåÆ CreateCourseResultDto
        ŌåÆ CreateCourseResponseDto
```
