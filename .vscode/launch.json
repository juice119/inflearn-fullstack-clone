{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "NestJS: pnpm Debug",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "start:local-debug"],
      "cwd": "${workspaceFolder}/backend",
      "autoAttachChildProcesses": true,
      "restart": true,
      "sourceMaps": true,
      "console": "integratedTerminal"
    },
    {
      "name": "🚀 Next.js: 내장 브라우저 원클릭 디버깅",
      "type": "node-terminal",
      "request": "launch",
      "cwd": "${workspaceFolder}/frontend",
      "command": "pnpm dev",
      "skipFiles": ["<node_internals>/**"],
      "serverReadyAction": {
        "pattern": "- Local:\\s+(https?://localhost:\\d+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      }
    }
  ]
}
